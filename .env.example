# Root .env.example for reference
# This file shows all environment variables used across the project

# ===========================================
# ANDROID CLIENT CONFIGURATION
# ===========================================
# Use these URLs in your Android app configuration
API_BASE_URL=http://10.0.2.2:5000
CHAT_API_BASE_URL=http://10.0.2.2:3000

# Production URLs (Render)
# API_BASE_URL=https://agrigo-api-server.onrender.com
# CHAT_API_BASE_URL=https://agrigo-chatbot.onrender.com

# ===========================================
# SERVER CONFIGURATION (See server/.env.example)
# ===========================================
# Flask, Node.js, Database, APIs - all configured in server/.env

# ===========================================
# WEBSITE/UI CONFIGURATION (agrinova-ui-main)
# ===========================================
VITE_API_BASE_URL=http://localhost:5000
VITE_CHAT_API_BASE_URL=http://localhost:3000

# Production URLs
# VITE_API_BASE_URL=https://agrigo-api-server.onrender.com
# VITE_CHAT_API_BASE_URL=https://agrigo-chatbot.onrender.com

